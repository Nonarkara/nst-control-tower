# CTM-01 API local environment
#
# ── SETUP ────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Paste your keys below (every key is OPTIONAL — the dashboard degrades
#    gracefully and shows a "needs key" pill on any feed whose key is missing,
#    rather than rendering a silent empty layer).
# 3. Restart the API. Check which keys the server sees at any time:
#       curl localhost:8787/api/health/keys
#    (returns presence only — never the key values).
# Free-tier signup links are listed next to each key below.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase / Postgres persistence for the semantic city twin.
# Paste the Supabase Transaction Pooler connection string here, or use
# DATABASE_URL if you prefer a generic Postgres name.
SUPABASE_DB_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Supabase requires SSL. The API auto-enables SSL for Supabase hosts; keep this
# explicit if your connection string uses a custom host or proxy.
DATABASE_SSL=true

# Keep this small for Supabase pooler friendliness.
DATABASE_POOL_MAX=3

# ── AI / Chat ────────────────────────────────────────────────────────────────

# Gemini 2.5 Flash — powers the CTM-Concierge chat.
# Free tier: 15 RPM. Register at https://aistudio.google.com/
GEMINI_API_KEY=

# Optional Ollama fallback (local qwen2.5:1.5b when Gemini quota hit)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── AIS / Maritime ───────────────────────────────────────────────────────────

# AISStream.io real-time vessel positions (Gulf of Thailand bbox)
# Free with registration at https://aisstream.io
AISSTREAM_TOKEN=

# ── Air quality ──────────────────────────────────────────────────────────────

# AQICN (World Air Quality Index) — Chonburi PCD station cross-validation
# Free with registration at https://aqicn.org/data-platform/token/
AQICN_TOKEN=

# ── Financial markets ────────────────────────────────────────────────────────

# Financial Modeling Prep — SET Bangkok + global indices + forex
# Free tier: 250 req/day. https://site.financialmodelingprep.com/
FMP_API_KEY=

# FRED (St. Louis Fed) — US macro, DGS10, VIX, DEXTHUS (THB/USD)
# Free: 120,000 req/day. https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Social / Open data ───────────────────────────────────────────────────────

# data.go.th CKAN API token (optional — increases rate limits)
# DATA_GO_TH_TOKEN=

# Facebook page token + page ID for official Mueang Chonburi page posts
# FACEBOOK_PAGE_TOKEN=
# FACEBOOK_PAGE_ID=

# ── Transit ─────────────────────────────────────────────────────────────────

# ViaBus (Thai transit real-time positions)
# VIABUS_TOKEN=
# VIABUS_BASE_URL=

# ── MQTT bridge (real-time sensor ingestion) ─────────────────────────────────

# MQTT broker for sensor telemetry (IoT devices, weather stations)
# MQTT_BROKER_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_TOPICS=chonburi/sensors/#

# ── Server ───────────────────────────────────────────────────────────────────

# NODE_ENV — "development" or "production"
# ENVIRONMENT=development

# PORT=8787
# HOST=0.0.0.0
