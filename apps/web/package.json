{
  "name": "@nst/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "wrangler pages deploy dist --project-name nst-control-tower"
  },
  "dependencies": {
    "@nst/shared": "workspace:*",
    "@deck.gl/aggregation-layers": "^9.2.11",
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "@deck.gl/react": "^9.2.11",
    "@fontsource/ibm-plex-sans-thai": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@loaders.gl/3d-tiles": "^4.4.2",
    "maplibre-gl": "^5.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/geojson": "^7946.0.14",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "osmtogeojson": "3.0.0-beta.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "wrangler": "^4.0.0"
